---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getCategoryHref, getPostHref, getPublishedPosts, getTagHref, groupPostsBy } from '../../utils/blog';

const posts = await getPublishedPosts();
const categories = groupPostsBy(posts, 'category').slice(0, 6);
const tags = groupPostsBy(posts, 'tags').slice(0, 10);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-title">
				<p class="eyebrow">Blog</p>
				<h1>全部文章</h1>
				<p>这里展示所有已发布的内容。后续你可以继续加分类、标签页、搜索和归档页。</p>
			</section>
			<section class="browse-grid">
				<article class="browse-card">
					<div class="browse-head">
						<h2>分类</h2>
						<a href="/categories">查看全部</a>
					</div>
					<ul class="browse-list">
						{
							categories.map((category) => (
								<li>
									<a href={getCategoryHref(category.name)}>{category.name}</a>
									<span>{category.count}</span>
								</li>
							))
						}
					</ul>
				</article>
				<article class="browse-card">
					<div class="browse-head">
						<h2>标签</h2>
						<a href="/tags">查看全部</a>
					</div>
					<ul class="chip-list">
						{
							tags.map((tag) => (
								<li>
									<a href={getTagHref(tag.name)}>{tag.name}</a>
								</li>
							))
						}
					</ul>
				</article>
				<article class="browse-card browse-card-wide">
					<div class="browse-head">
						<h2>归档</h2>
						<a href="/archive">按时间浏览</a>
					</div>
					<p class="browse-copy">
						如果你更习惯按时间线回看内容，可以直接去归档页按年份浏览全部文章。
					</p>
				</article>
			</section>
			<section class="post-list">
				{
					posts.map((post) => (
						<article class="post-item">
							<p class="meta">
								<a href={getCategoryHref(post.data.category)}>{post.data.category}</a>
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h2><a href={getPostHref(post)}>{post.data.title}</a></h2>
							<p>{post.data.description}</p>
							{post.data.tags.length > 0 && (
								<ul class="tags">
									{post.data.tags.map((tag) => (
										<li>
											<a href={getTagHref(tag)}>{tag}</a>
										</li>
									))}
								</ul>
							)}
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-title {
		margin-bottom: 1.5rem;
	}

	.eyebrow {
		margin-bottom: 0.8rem;
		font-size: 0.82rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	.post-list {
		display: grid;
		gap: 1rem;
	}

	.browse-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 1.25rem;
	}

	.browse-card,
	.post-item {
		padding: 1.5rem;
		border-radius: 1.5rem;
		border: 1px solid rgba(var(--border), 0.8);
		background: rgba(255, 253, 249, 0.84);
		box-shadow: var(--card-shadow);
	}

	.browse-card-wide {
		grid-column: 1 / -1;
	}

	.browse-head,
	.browse-list li {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.browse-head {
		margin-bottom: 1rem;
	}

	.browse-head h2 {
		margin: 0;
		font-size: 1.2rem;
	}

	.browse-list,
	.chip-list {
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.browse-list {
		display: grid;
		gap: 0.8rem;
	}

	.browse-list li span {
		color: rgb(var(--gray));
	}

	.chip-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.chip-list li a,
	.tags li a {
		display: inline-block;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		background: rgba(var(--gray-light), 0.65);
		font-size: 0.82rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
	}

	.browse-copy {
		margin: 0;
		color: rgb(var(--gray));
	}

	.post-item h2 {
		margin-bottom: 0.6rem;
	}

	.post-item h2 a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.post-item h2 a:hover {
		color: rgb(var(--accent-strong));
	}

	.meta {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		font-size: 0.88rem;
		color: rgb(var(--gray));
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		padding: 0;
		margin: 1rem 0 0;
		list-style: none;
	}

	@media (max-width: 720px) {
		.browse-grid {
			grid-template-columns: 1fr;
		}

		.meta {
			flex-direction: column;
			gap: 0.4rem;
		}
	}
</style>
