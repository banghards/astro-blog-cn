---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCategoryHref, getPublishedPosts, groupPostsByYear } from '../utils/blog';

const posts = await getPublishedPosts();
const archive = groupPostsByYear(posts);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`归档 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-title">
				<p class="eyebrow">Archive</p>
				<h1>归档</h1>
				<p>按年份回看所有文章，适合快速检查这个博客到底积累了什么。</p>
			</section>

			<section class="archive-list">
				{
					archive.map((group) => (
						<section class="year-block">
							<div class="year-head">
								<h2>{group.year}</h2>
								<span>{group.count} 篇</span>
							</div>
							<ul>
								{group.posts.map((post) => (
									<li>
										<div class="post-main">
											<h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
											<p>{post.data.description}</p>
										</div>
										<div class="post-meta">
											<a href={getCategoryHref(post.data.category)}>{post.data.category}</a>
											<FormattedDate date={post.data.pubDate} />
										</div>
									</li>
								))}
							</ul>
						</section>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-title {
		margin-bottom: 1.5rem;
	}

	.eyebrow {
		margin-bottom: 0.8rem;
		font-size: 0.82rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}

	.archive-list {
		display: grid;
		gap: 1rem;
	}

	.year-block {
		padding: 1.5rem;
		border-radius: 1.5rem;
		border: 1px solid rgba(var(--border), 0.8);
		background: rgba(255, 253, 249, 0.84);
		box-shadow: var(--card-shadow);
	}

	.year-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.year-head h2 {
		margin: 0;
	}

	.year-head span {
		color: rgb(var(--gray));
	}

	.year-block ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1rem;
	}

	.year-block li {
		display: flex;
		justify-content: space-between;
		gap: 1.5rem;
		padding-top: 1rem;
		border-top: 1px solid rgba(var(--border), 0.8);
	}

	.year-block li:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.post-main h3 {
		margin-bottom: 0.35rem;
	}

	.post-main h3 a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.post-main h3 a:hover {
		color: rgb(var(--accent-strong));
	}

	.post-main p {
		margin: 0;
		color: rgb(var(--gray));
	}

	.post-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.35rem;
		white-space: nowrap;
		font-size: 0.88rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 720px) {
		.year-block li {
			flex-direction: column;
			gap: 0.8rem;
		}

		.post-meta {
			align-items: flex-start;
		}
	}
</style>
