---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav>
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
			<p>中文个人博客</p>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/archive">归档</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 1rem 1.25rem;
		backdrop-filter: blur(18px);
		background: rgba(250, 247, 240, 0.75);
		border-bottom: 1px solid rgba(var(--border), 0.7);
	}

	nav {
		width: min(1120px, calc(100% - 1rem));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand a,
	.brand a.active {
		font-size: 1.1rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: rgb(var(--black));
		text-decoration: none;
	}

	.brand p {
		margin: 0.2rem 0 0;
		font-size: 0.82rem;
		color: rgb(var(--gray));
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		flex-wrap: wrap;
	}

	:global(.internal-links a) {
		padding: 0.7rem 0.95rem;
		border-radius: 999px;
		border-bottom: none;
		text-decoration: none;
		font-size: 0.95rem;
		color: rgb(var(--gray-dark));
	}

	:global(.internal-links a.active) {
		background: rgb(var(--accent));
		color: rgb(var(--surface));
	}

	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
