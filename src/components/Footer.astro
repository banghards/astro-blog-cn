---
import { SITE_AUTHOR, SITE_EMAIL, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer class="site-footer">
	<div>
		<strong>{SITE_TITLE}</strong>
		<p>持续记录，长期表达，把零散的想法整理成可回看的作品。</p>
	</div>
	<div class="footer-meta">
		<span>© {today.getFullYear()} {SITE_AUTHOR}</span>
		<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a>
	</div>
</footer>

<style>
	.site-footer {
		width: min(1120px, calc(100% - 2rem));
		margin: 3rem auto 0;
		padding: 2rem 0 4rem;
		border-top: 1px solid rgba(var(--border), 0.8);
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		color: rgb(var(--gray));
	}

	.site-footer p {
		margin: 0.5rem 0 0;
		max-width: 34rem;
	}

	.footer-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.35rem;
		white-space: nowrap;
	}

	.footer-meta a {
		color: inherit;
		text-decoration: none;
	}

	.footer-meta a:hover {
		color: rgb(var(--black));
	}

	@media (max-width: 720px) {
		.site-footer {
			flex-direction: column;
			padding-bottom: 2.5rem;
		}

		.footer-meta {
			align-items: flex-start;
		}
	}
</style>
